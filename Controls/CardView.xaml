<UserControl x:Class="StudySystem.Controls.CardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StudySystem"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="CardObject">
        <Border BorderBrush="#292929" BorderThickness="6"
                CornerRadius="10" Padding="20"
                Width="560" Height="680">
            <StackPanel x:Name="CardData"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,30,0,40">
                    <TextBlock x:Name="CardFrontText"
                               Foreground="#C6C6C6" FontSize="56" FontFamily="Meiryo UI"
                               Margin="0,0,20,0" HorizontalAlignment="Center" Opacity="1.0"/>
                    <TextBlock x:Name="CardExtrasText"
                               Foreground="#C6C6C6" FontSize="46" FontFamily="Meiryo UI"
                               Margin="20,0,0,0" HorizontalAlignment="Center" Opacity="1.0"/>
                    <TextBlock x:Name="CardReadingText"
                               Foreground="#AFAFAF" FontSize="30" FontFamily="Meiryo UI"
                               Margin="0,0,0,0" HorizontalAlignment="Center" Opacity="0.6"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,40">
                    <TextBlock x:Name="CardPronunciationText" Foreground="#888888"
                               FontSize="20" FontFamily="Meiryo UI" HorizontalAlignment="Center"/>
                </StackPanel>
                <Grid x:Name="AnswerContainer" HorizontalAlignment="Center"
                      Opacity="1.0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Answer: " Foreground="#C6C6C6"
                               FontSize="22" FontFamily="Meiryo UI"
                               Margin="16,-20,0,0" TextAlignment="Center"/>
                    <TextBlock x:Name="CardAnswerText" Foreground="#C6C6C6"
                               FontSize="44" FontFamily="Meiryo UI"
                               Margin="0,0,0,0" HorizontalAlignment="Center"
                               TextAlignment="Center" Visibility="Hidden"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
