<Window x:Class="StudySystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudySystem"
        xmlns:controls="clr-namespace:StudySystem.Controls"
        xmlns:screens="clr-namespace:StudySystem.Screens"
        mc:Ignorable="d"
        Title="Study System" 
        Height="700" 
        Width="1100" 
        MinWidth="800" 
        MinHeight="500" 
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/App.ico"
        WindowState="Maximized">
    <Grid x:Name="MainGrid" Background="#202020">

        <!-- HomeScreen -->
        <screens:HomeScreenView x:Name="HomeScreen" Visibility="Visible"/>

        <!-- StudyScreen -->
        <Grid x:Name="StudyScreen" Background="#202020" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,100,660,0">
                <Button x:Name="ImportDeckButton"
                        Width="30" Height="30"
                        BorderThickness="2"
                        Background="#464646" Foreground="#C6C6C6"
                        Click="ImportDeckButton_Click">
                    <Grid>
                        <Rectangle Width="3" Height="20" Fill="#C6C6C6"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Rectangle Width="20" Height="3" Fill="#C6C6C6"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="700">
                <TextBlock Text="Study Screen"
                           Foreground="#E5E5E5"
                           FontSize="80"
                           FontFamily="Segoe UI"
                           Margin="5,5,5,5"
                           HorizontalAlignment="Center" >
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#3E454B"
                                          BlurRadius="0"
                                          ShadowDepth="1"
                                          Opacity="1" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Choose a Deck"
                           FontSize="20"
                           Foreground="#C6C6C6"
                           Margin="0,0,0,10"/>
                <ComboBox x:Name="DeckSelection"
                          Height="26"
                          Margin="0,0,0,20"
                          DisplayMemberPath="Name"
                          Padding="8,0,0,0"
                          Background="#202020"
                          Foreground="#000000"
                          BorderBrush="#C6C6C6"
                          BorderThickness="1"
                          VerticalContentAlignment="Center"
                          HorizontalContentAlignment="Left">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="Padding" Value="4,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Background" Value="#2E2E2E"/>
                            <Setter Property="Foreground" Value="#C6C6C6"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <Button Content="Study"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to StudyScreen - WIP"
                        Click="DeckStudyButton_Click"/>
                <Button Content="Back"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to HomeScreen atm, not true back - WIP"
                        Click="BackToHomeButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- BuilderScreen -->
        <screens:BuilderScreenView x:Name="BuilderScreen" Visibility="Collapsed"/>

        <!-- SettingsScreen -->
        <Grid x:Name="SettingsScreen" Background="#202020" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="700">
                <TextBlock Text="Settings Screen - WIP"
                           Foreground="#C6C6C6"
                           FontSize="30"
                           FontFamily="Segoe UI"
                           Margin="5"
                           HorizontalAlignment="Center" >
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#3E454B"
                                          BlurRadius="0"
                                          ShadowDepth="1"
                                          Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Button Content="Back"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to HomeScreen atm, not true back - WIP"
                        Click="BackToHomeButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- CardScreen -->
        <Grid x:Name="CardScreen" Background="#202020" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <controls:CardView Grid.Row="0" x:Name="MainCardView"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="1"
                        x:Name="DifficultyContainer" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,20,25,0" Visibility="Visible" Opacity="1.0">
                <Button x:Name="HardButton" Content="H a r d"
                        Style="{StaticResource DifficultyButtonStyle}"
                        Margin="0,0,10,0" Background="#B94A48"
                        Click="HardButton_Click"/>
                <Button x:Name="NormalButton" Content="N o r m a l"
                        Style="{StaticResource DifficultyButtonStyle}"
                        Margin="10,0,10,0" Background="#C9A227"
                        Click="NormalButton_Click"/>
                <Button x:Name="EasyButton" Content="E a s y"
                        Style="{StaticResource DifficultyButtonStyle}"
                        Margin="10,0,0,0" Background="#4CAF50"
                        Click="EasyButton_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="160" Height="36" Margin="0,20,25,0">
                <Button x:Name="ShowAnswerButton" Content="A n s w e r"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Displays The Answer"
                        Visibility="Visible" IsEnabled="False" Opacity="0.4"
                        FontFamily="Segoe UI" FontSize="20"
                        Width="120" Height="32" Margin="34,0,0,0"
                        Click="ShowAnswerButton_Click"/>
                <Button x:Name="NextButton" Content="N e x t"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Goes To Next Card"
                        Visibility="Collapsed" IsEnabled="False"
                        FontFamily="Segoe UI" FontSize="20"
                        Width="100" Height="32" Margin="34,0,0,0"
                        Click="NextCardButton_Click"/>
            </StackPanel>
            <Button Grid.Row="3" Content="Back"
                    Style="{StaticResource MenuButtonStyle}"
                    ToolTip="Brings to StudyScreen atm, not true back - WIP"
                    FontFamily="Segoe UI" FontSize="24"
                    Width="120" Height="32" Margin="20,0,0,46"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Click="StudyButton_Click"/>
        </Grid>
    </Grid>
</Window>