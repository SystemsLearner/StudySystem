<Window x:Class="StudySystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudySystem"
        mc:Ignorable="d"
        Title="Study System" 
        Height="700" 
        Width="1100" 
        MinWidth="800" 
        MinHeight="500" 
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/App.ico"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="Foreground" Value="#C6C6C6"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#C6C6C6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Meiryo UI"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                VerticalAlignment="Stretch">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextOptions.TextFormattingMode="Display"
                                       TextOptions.TextRenderingMode="ClearType">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#3E454B"
                                                      BlurRadius="0"
                                                      ShadowDepth="1"
                                                      Opacity="0.85"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3A3A3A"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                    
                    
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DifficultyButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#C6C6C6"/>
            <Setter Property="BorderBrush" Value="#C6C6C6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.70"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>


                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid x:Name="MainGrid" Background="#202020">

        <Grid x:Name="HomeScreen" Background="#202020" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="700">
                <TextBlock Text="Study System"
                   Foreground="#C6C6C6"
                   FontSize="80"
                   FontFamily="Segoe UI"
                   Margin="5" 
                   HorizontalAlignment="Center" >
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#3E454B"
                                  BlurRadius="0"
                                  ShadowDepth="1"
                                  Opacity="1" />
                    </TextBlock.Effect>
                </TextBlock>
                <Button Content="S t u d y"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="StudyButton_Click"/>

                <Button Content="S e t t i n g s"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="SettingsButton_Click"/>

                <Button Content="E x i t"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="ExitButton_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="StudyScreen" Background="#202020" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="700">
                <TextBlock Text="Study Screen"
                           Foreground="#C6C6C6"
                           FontSize="80"
                           FontFamily="Segoe UI"
                           Margin="5"
                           HorizontalAlignment="Center" >
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#3E454B"
                                          BlurRadius="0"
                                          ShadowDepth="1"
                                          Opacity="1" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Choose a Deck"
                           FontSize="20"
                           Foreground="#C6C6C6"
                           Margin="0,0,0,10"/>
                <ComboBox x:Name="DeckSelection"
                          Height="26"
                          Margin="0,0,0,20"
                          DisplayMemberPath="Name"
                          Padding="8,0,0,0"
                          Background="#2E2E2E"
                          Foreground="#000000"
                          BorderBrush="#C6C6C6"
                          BorderThickness="1"
                          VerticalContentAlignment="Center"
                          HorizontalContentAlignment="Left">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="Padding" Value="4,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Background" Value="#2E2E2E"/>
                            <Setter Property="Foreground" Value="#C6C6C6"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <Button Content="S t u d y"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="DeckStudyButton_Click"/>
                <Button Content="B a c k"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BackToHomeButton_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="SettingsScreen" Background="#202020" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="700">
                <TextBlock Text="Settings Screen - WIP"
                           Foreground="#C6C6C6"
                           FontSize="80"
                           FontFamily="Segoe UI"
                           Margin="5"
                           HorizontalAlignment="Center" >
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#3E454B"
                                          BlurRadius="0"
                                          ShadowDepth="1"
                                          Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Button Content="B a c k"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BackToHomeButton_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="CardScreen" Background="#202020" Visibility="Collapsed">
            <Border BorderBrush="#292929" BorderThickness="6"
                    CornerRadius="10" Padding="20" Margin="680,200,680,200"/>
            <Button Content="B a c k"
                    Style="{StaticResource MenuButtonStyle}"
                    FontFamily="Segoe UI" FontSize="24"
                    Width="120" Height="32" Margin="20,0,0,46"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Click="StudyButton_Click"/>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="1920">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,30,0,40">
                    <TextBlock x:Name="CardFrontText"
                               Foreground="#C6C6C6" FontSize="56" FontFamily="Meiryo UI"
                               Margin="0,0,20,0" HorizontalAlignment="Center" Opacity="1.0"/>
                    <TextBlock x:Name="CardFuriganaText"
                               Foreground="#AFAFAF" FontSize="30" FontFamily="Meiryo UI"
                               Margin="0,0,0,0" HorizontalAlignment="Center" Opacity="0.6"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="4,30,0,40">
                    <TextBlock x:Name="CardIntonationText" Foreground="#888888"
                               FontSize="20" FontFamily="Meiryo UI" HorizontalAlignment="Center"/>
                </StackPanel>



                <Grid x:Name="AnswerContainer" HorizontalAlignment="Center"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Answer: "
                               Foreground="#C6C6C6"
                               FontSize="22"
                               FontFamily="Meiryo UI"
                               Margin="12,-20,0,0"
                               TextAlignment="Center"/>

                    <TextBlock x:Name="CardAnswerText"
                               Foreground="#C6C6C6"
                               FontSize="44"
                               FontFamily="Meiryo UI"
                               Margin="0,0,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="DifficultyContainer" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,0,0,0">
                    <Button x:Name="HardButton" IsEnabled="True"
                            Content="H a r d" FontFamily="Segoe UI" FontSize="14"
                            Style="{StaticResource DifficultyButtonStyle}"
                            Width="100" Height="24" Margin="0,0,10,0"
                            Background="#B94A48" BorderThickness="2" BorderBrush="#C6C6C6"
                            Click="HardButton_Click"/>
                    <Button x:Name="NormalButton" IsEnabled="True"
                            Content="N o r m a l" FontFamily="Segoe UI" FontSize="14"
                            Style="{StaticResource DifficultyButtonStyle}"
                            Width="100" Height="24" Margin="10,0,10,0"
                            Background="#C9A227" BorderThickness="2" BorderBrush="#C6C6C6"
                            Click="NormalButton_Click"/>
                    <Button x:Name="EasyButton" IsEnabled="True"
                            Content="E a s y" FontFamily="Segoe UI" FontSize="14"
                            Style="{StaticResource DifficultyButtonStyle}"
                            Width="100" Height="24" Margin="10,0,0,0"
                            Background="#4CAF50" BorderThickness="2" BorderBrush="#C6C6C6"
                            Click="EasyButton_Click"/>

                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Width="160"
                            Height="36"
                            Margin="0,20,0,0">
                    <Button x:Name="NextButton" Content="N e x t"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="Collapsed" IsEnabled="False"
                            FontFamily="Segoe UI" FontSize="20"
                            Width="100" Height="32" Margin="34,0,0,0"
                            Click="NextCardButton_Click"/>
                    
                    <Button x:Name="ShowAnswerButton" Content="A n s w e r"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="Visible" IsEnabled="True"
                            FontFamily="Segoe UI" FontSize="20"
                            Width="100" Height="32" Margin="34,0,0,0"
                            Click="ShowAnswerButton_Click"/>       
                    
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>