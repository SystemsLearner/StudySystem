<UserControl x:Class="StudySystem.Screens.StudyScreenView"
             x:Name="StudyScreen"
             Visibility="Collapsed"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:StudySystem.Controls"
             xmlns:local="clr-namespace:StudySystem.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- StudyScreen -->
    <Grid Background="#202020">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,100,660,0">
            
            <!-- ImportDeckButton -->
            <Button x:Name="ImportDeckButton"
                    Width="30" Height="30" BorderThickness="2"
                    Background="#464646" Foreground="#C6C6C6">
                <Grid>
                    <Rectangle Width="3" Height="20" Fill="#C6C6C6"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Rectangle Width="20" Height="3" Fill="#C6C6C6"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Button>
        </StackPanel>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="700">
            
            <!-- Title -->
            <TextBlock Text="Study Screen" Foreground="#E5E5E5"
                       FontSize="80" FontFamily="Segoe UI"
                       Margin="5,5,5,5" HorizontalAlignment="Center" >
                <TextBlock.Effect>
                    <DropShadowEffect Color="#3E454B" BlurRadius="0"
                                      ShadowDepth="1" Opacity="1" />
                </TextBlock.Effect>
            </TextBlock>
            
            <!-- DeckSelectionComboBox -->
            <TextBlock Text="Choose a Deck" FontSize="20"
                       Foreground="#C6C6C6" Margin="0,0,0,10"/>
            <ComboBox x:Name="DeckSelection"
                      Height="26" Margin="0,0,0,20" Padding="8,0,0,0"
                      DisplayMemberPath="Name"
                      Background="#202020" Foreground="#000000"
                      BorderBrush="#C6C6C6" BorderThickness="1"
                      VerticalContentAlignment="Center"
                      HorizontalContentAlignment="Left">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Height" Value="28"/>
                        <Setter Property="Padding" Value="4,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Background" Value="#2E2E2E"/>
                        <Setter Property="Foreground" Value="#C6C6C6"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
            
            <!-- StudyScreenButton -->
            <Button x:Name="StudyButton" Content="Study"
                    Style="{StaticResource MenuButtonStyle}"
                    ToolTip="Brings to StudyScreen - WIP"/>
            
            <!-- HomeScreenButton -->
            <Button x:Name="BackButton" Content="Back"
                    Style="{StaticResource MenuButtonStyle}"
                    ToolTip="Brings to HomeScreen atm, not true back - WIP"/>
        </StackPanel>
    </Grid>
</UserControl>
