<UserControl x:Class="StudySystem.Screens.SettingsScreenView"
             x:Name="SettingsScreen"
             Visibility="Collapsed"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:StudySystem.Controls"
             xmlns:local="clr-namespace:StudySystem.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#202020" Visibility="Visible">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="700">
            <TextBlock Text="Settings Screen - WIP" Foreground="#C6C6C6"
                       FontSize="30" FontFamily="Segoe UI"
                       Margin="5" HorizontalAlignment="Center" >
                <TextBlock.Effect>
                    <DropShadowEffect Color="#3E454B" BlurRadius="0"
                                      ShadowDepth="1" Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>
            <Button x:Name="HomeButton"
                    Content="Back" Style="{StaticResource MenuButtonStyle}"
                    ToolTip="Brings to HomeScreen atm, not true back - WIP"/>
        </StackPanel>
    </Grid>
</UserControl>
