<UserControl x:Class="StudySystem.Screens.HomeScreenView"
             x:Name="HomeScreen"
             Visibility="Visible"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:StudySystem.Controls"
             xmlns:local="clr-namespace:StudySystem.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#202020">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center" Width="700">
            <Grid x:Name="TitleContainer">
                <TextBlock Text="Study System" Foreground="#C6C6C6"
                           FontSize="80" FontFamily="Segoe UI"
                           Margin="5,5,5,35" HorizontalAlignment="Center" >
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#3E454B" BlurRadius="0"
                                          ShadowDepth="1" Opacity="1" />
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>
            <!-- Temp Deck Building Button -->
            <Grid x:Name="TempDeckButton"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom">
                <Button x:Name="TemplateButton"
                        ToolTip="Temporary dev tool: creates a template deck for testing."
                        Width="140" Height="80" FocusVisualStyle="{x:Null}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#353535"/>
                            <Setter Property="BorderBrush" Value="#C6C6C6"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ButtonBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonBorder"
                                                        Property="Background" Value="#3A3A3A"/>
                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ButtonBorder"
                                                        Property="Background" Value="#505050"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock TextAlignment="Center" Foreground="#C6C6C6"
                               FontFamily="Segoe UI" FontSize="22">
                    Create Deck
                    <LineBreak/>
                    (Template)
                    </TextBlock>
                </Button>
            </Grid>
            <StackPanel x:Name="ButtonsContainer">
                <Button x:Name="StudyButton"
                        Content="Study" Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to StudyScreen - WIP"/>

                <Button x:Name="BuilderButton"
                        Content="Edit Deck" Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to EditDeckScreen - WIP"/>

                <Button x:Name="SettingsButton"
                        Content="Settings" Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to SettingsScreen - WIP"/>

                <Button x:Name="ExitButton"
                        Content="Exit" Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Closes the program."/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
