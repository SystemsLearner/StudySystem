<Window x:Class="StudySystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudySystem"
        xmlns:controls="clr-namespace:StudySystem.Controls"
        mc:Ignorable="d"
        Title="Study System" 
        Height="700" 
        Width="1100" 
        MinWidth="800" 
        MinHeight="500" 
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/App.ico"
        WindowState="Maximized">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/MainStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid x:Name="MainGrid" Background="#202020">

        <!-- HomeScreen -->
        <Grid x:Name="HomeScreen" Background="#202020" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="700">
                <Grid x:Name="TitleContainer">
                    <TextBlock Text="Study System" Foreground="#C6C6C6"
                               FontSize="80" FontFamily="Segoe UI"
                               Margin="5,5,5,35" HorizontalAlignment="Center" >
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#3E454B" BlurRadius="0"
                                              ShadowDepth="1" Opacity="1" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
                
                <!-- Temp Deck Building Button -->
                <Grid x:Name="TempDeckButton"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom">
                    <Button Click="CreateTemplateDeck_Click"
                            ToolTip="Temporary dev tool: creates a template deck for testing."
                            Width="140" Height="80" FocusVisualStyle="{x:Null}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#353535"/>
                                <Setter Property="BorderBrush" Value="#C6C6C6"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                                            Property="Background" Value="#3A3A3A"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                                            Property="Background" Value="#505050"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock TextAlignment="Center"
                                   FontFamily="Segoe UI" FontSize="22"
                                   Foreground="#C6C6C6">
                            Create Deck
                            <LineBreak/>
                            (Template)
                        </TextBlock>
                    </Button>
                </Grid>

                <StackPanel x:Name="ButtonsContainer">
                    <Button Content="Study" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="Brings to StudyScreen - WIP"
                            Click="StudyButton_Click"/>

                    <Button Content="Edit Deck" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="Brings to EditDeckScreen - WIP"
                            Click="BuilderButton_Click"/>

                    <Button Content="Settings" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="Brings to SettingsScreen - WIP"
                            Click="SettingsButton_Click"/>

                    <Button Content="Exit" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="Closes the program."
                            Click="ExitButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- StudyScreen -->
        <Grid x:Name="StudyScreen" Background="#202020" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,100,660,0">
                <Button x:Name="ImportDeckButton"
                        Width="30" Height="30"
                        BorderThickness="2"
                        Background="#464646" Foreground="#C6C6C6"
                        Click="ImportDeckButton_Click">
                    <Grid>
                        <Rectangle Width="3" Height="20" Fill="#C6C6C6"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Rectangle Width="20" Height="3" Fill="#C6C6C6"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="700">
                <TextBlock Text="Study Screen"
                           Foreground="#E5E5E5"
                           FontSize="80"
                           FontFamily="Segoe UI"
                           Margin="5,5,5,5"
                           HorizontalAlignment="Center" >
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#3E454B"
                                          BlurRadius="0"
                                          ShadowDepth="1"
                                          Opacity="1" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Choose a Deck"
                           FontSize="20"
                           Foreground="#C6C6C6"
                           Margin="0,0,0,10"/>
                <ComboBox x:Name="DeckSelection"
                          Height="26"
                          Margin="0,0,0,20"
                          DisplayMemberPath="Name"
                          Padding="8,0,0,0"
                          Background="#202020"
                          Foreground="#000000"
                          BorderBrush="#C6C6C6"
                          BorderThickness="1"
                          VerticalContentAlignment="Center"
                          HorizontalContentAlignment="Left">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="Padding" Value="4,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Background" Value="#2E2E2E"/>
                            <Setter Property="Foreground" Value="#C6C6C6"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <Button Content="Study"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to StudyScreen - WIP"
                        Click="DeckStudyButton_Click"/>
                <Button Content="Back"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to HomeScreen atm, not true back - WIP"
                        Click="BackToHomeButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- BuilderScreen -->
        <Grid x:Name="BuilderScreen" Margin="0,0,0,0"
              IsEnabled="False" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Grid Grid.Row="0">
                <TextBlock Text="Card Editor" Foreground="#C6C6C6"/>
            </Grid>

            <!-- Card Builder -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Inputs -->
                <Grid Grid.Column="0" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Front" Foreground="#C6C6C6" Grid.Row="0"
                               Height="40" FontSize="24" HorizontalAlignment="Center"
                               Margin="0,0,0,4" Padding="8,5"/>
                    <TextBox x:Name="BuilderFrontTextBox" Grid.Row="1" Margin="0,0,0,10"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             TextChanged="BuilderFields_TextChanged"
                             Height="44" Width="200" FontSize="20" Padding="8,4"/>
                    <TextBlock Text="Reading" Foreground="#C6C6C6" Grid.Row="2"
                               Height="40" FontSize="24" HorizontalAlignment="Center"
                               Margin="0,0,0,4" Padding="8,5"/>
                    <TextBox x:Name="BuilderReadingTextBox" Grid.Row="3" Margin="0,0,0,10"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             TextChanged="BuilderFields_TextChanged"
                             Height="44" Width="200" FontSize="20" Padding="8,4"/>
                    <TextBlock Text="Pronunciation" Foreground="#C6C6C6" Grid.Row="4"
                               Height="40" FontSize="24" HorizontalAlignment="Center"
                               Margin="0,0,0,4" Padding="8,5"/>
                    <TextBox x:Name="BuilderPronunciationTextBox" Grid.Row="5" Margin="0,0,0,10"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             TextChanged="BuilderFields_TextChanged"
                             Height="44" Width="200" FontSize="20" Padding="8,4"/>
                    <TextBlock Text="Answer" Foreground="#C6C6C6" Grid.Row="6"
                               Height="40" FontSize="24" HorizontalAlignment="Center"
                               Margin="0,0,0,4" Padding="8,5"/>
                    <TextBox x:Name="BuilderAnswerTextBox" Grid.Row="7"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             TextChanged="BuilderFields_TextChanged"
                             Height="44" Width="200" FontSize="20" Padding="8,4"/>
                </Grid>

                <!-- Preview -->
                <Grid Grid.Column="1">
                    <controls:CardView x:Name="EditorCardView"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Home" Margin="0,0,20,20"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to HomeScreen atm, not true back - WIP"
                        Click="BackToHomeButton_Click"/>
                <Button x:Name="PreviousCard" Content="Previous" Margin="0,0,20,20"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Does Nothing Currently - WIP"/>
                <Button x:Name="NextCard" Content="Next" Margin="0,0,20,20"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Does Nothing Currently - WIP"/>
                <Button x:Name="AddCard" Content="Add" Margin="0,0,0,20"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Does Nothing Currently - WIP"/>
                <Button x:Name="DeleteCard" Content="Remove" Margin="20,0,0,20"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Does Nothing Currently - WIP"/>
                <Button x:Name="Save" Content="Save" Margin="20,0,0,20"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Does Nothing Currently - WIP"/>
            </StackPanel>
            
            <!-- ComboBoxes -->
            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Left" Margin="20,0,0,20">
                <ComboBox x:Name="DeckComboBox" Width="200"
                          Style="{StaticResource BuilderComboBoxStyle}"
                          ItemContainerStyle="{StaticResource BuilderComboBoxItemStyle}"
                          Margin="0,0,0,0" DisplayMemberPath="DisplayName"
                          SelectionChanged="DeckComboBox_SelectionChanged"/>
                <ComboBox x:Name="CardComboBox" Width="250"
                          Style="{StaticResource BuilderComboBoxStyle}"
                          ItemContainerStyle="{StaticResource BuilderComboBoxItemStyle}"
                          Margin="0,0,0,0" DisplayMemberPath="DisplayName"
                          SelectionChanged="CardComboBox_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- SettingsScreen -->
        <Grid x:Name="SettingsScreen" Background="#202020" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="700">
                <TextBlock Text="Settings Screen - WIP"
                           Foreground="#C6C6C6"
                           FontSize="30"
                           FontFamily="Segoe UI"
                           Margin="5"
                           HorizontalAlignment="Center" >
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#3E454B"
                                          BlurRadius="0"
                                          ShadowDepth="1"
                                          Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Button Content="Back"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Brings to HomeScreen atm, not true back - WIP"
                        Click="BackToHomeButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- CardScreen -->
        <Grid x:Name="CardScreen" Background="#202020" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <controls:CardView Grid.Row="0" x:Name="MainCardView"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="1"
                        x:Name="DifficultyContainer" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,20,25,0" Visibility="Visible" Opacity="1.0">
                <Button x:Name="HardButton" Content="H a r d"
                        Style="{StaticResource DifficultyButtonStyle}"
                        Margin="0,0,10,0" Background="#B94A48"
                        Click="HardButton_Click"/>
                <Button x:Name="NormalButton" Content="N o r m a l"
                        Style="{StaticResource DifficultyButtonStyle}"
                        Margin="10,0,10,0" Background="#C9A227"
                        Click="NormalButton_Click"/>
                <Button x:Name="EasyButton" Content="E a s y"
                        Style="{StaticResource DifficultyButtonStyle}"
                        Margin="10,0,0,0" Background="#4CAF50"
                        Click="EasyButton_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="160" Height="36" Margin="0,20,25,0">
                <Button x:Name="ShowAnswerButton" Content="A n s w e r"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Displays The Answer"
                        Visibility="Visible" IsEnabled="False" Opacity="0.4"
                        FontFamily="Segoe UI" FontSize="20"
                        Width="120" Height="32" Margin="34,0,0,0"
                        Click="ShowAnswerButton_Click"/>
                <Button x:Name="NextButton" Content="N e x t"
                        Style="{StaticResource MenuButtonStyle}"
                        ToolTip="Goes To Next Card"
                        Visibility="Collapsed" IsEnabled="False"
                        FontFamily="Segoe UI" FontSize="20"
                        Width="100" Height="32" Margin="34,0,0,0"
                        Click="NextCardButton_Click"/>
            </StackPanel>
            <Button Grid.Row="3" Content="Back"
                    Style="{StaticResource MenuButtonStyle}"
                    ToolTip="Brings to StudyScreen atm, not true back - WIP"
                    FontFamily="Segoe UI" FontSize="24"
                    Width="120" Height="32" Margin="20,0,0,46"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Click="StudyButton_Click"/>
        </Grid>
    </Grid>
</Window>